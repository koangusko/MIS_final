# ── 對外網址（單一事實來源；OAuth callback / LINE webhook / 邀請連結都依它組）──
APP_BASE_URL=

# ── 後端 ──
PORT=8080
SESSION_SECRET=

# ── 資料庫（PostgreSQL）──
# 例：postgresql://USER:PASSWORD@db:5432/screenpact
DATABASE_URL=

# ── Google OAuth 2.0 ──
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── 多模態 LLM（OpenCode / Go）──
OPENCODE_API_KEY=
OPENCODE_BASE_URL=
LLM_MODEL=

# ── LINE Messaging API ──
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ── 截圖儲存目錄（私有 volume）──
UPLOAD_DIR=/data/uploads

# ── 時區（日/週邊界、「昨天」一律台北時間）──
TZ=Asia/Taipei

# ── docker compose 本機 DB 預設（非機密；正式環境請改）──
POSTGRES_USER=screenpact
POSTGRES_PASSWORD=screenpact
POSTGRES_DB=screenpact
